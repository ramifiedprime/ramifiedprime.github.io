% SYMBOL DEFINING COMMANDS

\newcommand{\@NewSymbol}[3]{%
    \expandafter\def\csname#1\endcsname{\csname#2\endcsname{#3}}%
}%
\newcommand{\newsymbolscommand}[3]{%
    \expandafter\def\csname #1\endcsname{%
        \def\@CreateMyCommand####1{%
            \@NewSymbol{#2####1}{#3}{####1}%
        }%
        \forcsvlist{\@CreateMyCommand}%
    }%
}%
\newsymbolscommand{ovsymbols}{ov}{overline}%
\newsymbolscommand{calsymbols}{c}{mathcal}%
\newsymbolscommand{upsymbols}{}{textup}%
\newsymbolscommand{operatorsymbols}{}{MathOperator}%
\newsymbolscommand{fraksymbols}{f}{mathfrak}%
\newsymbolscommand{scrsymbols}{s}{mathscr}
\newsymbolscommand{boldsymbols}{b}{mathbf}
\newcommand{\bbsymbols}{%
    \def\@CreateMyCommand##1{%
        \@NewSymbol{##1##1}{mathbb}{##1}%
    }%
    \forcsvlist{\@CreateMyCommand}%
}%



% Some common ones
